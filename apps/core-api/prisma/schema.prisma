generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SpaceRole {
  OWNER
  MEMBER
}

enum NodeType {
  NOTE
  TASK
  DECISION
}

enum NodeStatus {
  TODO
  DOING
  DONE
}

enum TimelineEventType {
  NODE_CREATED
  NODE_UPDATED
  NODE_STATUS_CHANGED
}

enum TimelineTargetType {
  NODE
}

enum TimelineNodeType {
  MAINLINE_PROGRESS
  BRANCH_CREATED
  DECISION
  EXTERNAL_EVENT
  COMPLETED
  INTERRUPTED
}

model User {
  id          String      @id @default(cuid())
  email       String      @unique
  displayName String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  memberships Membership[]
  spaces      Space[]     @relation("SpaceOwner")
}

model Space {
  id            String         @id @default(cuid())
  name          String
  slug          String         @unique
  description   String?
  ownerId       String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  owner         User           @relation("SpaceOwner", fields: [ownerId], references: [id])
  members       Membership[]
  nodes         Node[]
  nodeRelations NodeRelation[]
  timeline      TimelineEvent[]

  @@index([ownerId, createdAt])
}

model Membership {
  id        String    @id @default(cuid())
  userId    String
  spaceId   String
  role      SpaceRole @default(MEMBER)
  createdAt DateTime  @default(now())
  space     Space     @relation(fields: [spaceId], references: [id])
  user      User      @relation(fields: [userId], references: [id])

  @@unique([userId, spaceId])
}

model Node {
  id              String         @id @default(cuid())
  spaceId         String
  title           String
  content         String?
  nodeType        NodeType       @default(NOTE)
  status          NodeStatus     @default(TODO)
  orderIndex      Int
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  space           Space          @relation(fields: [spaceId], references: [id])
  outgoingEdges   NodeRelation[] @relation("NodeRelationSource")
  incomingEdges   NodeRelation[] @relation("NodeRelationTarget")

  @@unique([spaceId, orderIndex])
  @@index([spaceId, orderIndex])
}

model NodeRelation {
  id           String   @id @default(cuid())
  spaceId      String
  sourceNodeId String
  targetNodeId String
  relationType String
  createdAt    DateTime @default(now())
  space        Space    @relation(fields: [spaceId], references: [id])
  sourceNode   Node     @relation("NodeRelationSource", fields: [sourceNodeId], references: [id])
  targetNode   Node     @relation("NodeRelationTarget", fields: [targetNodeId], references: [id])

  @@unique([spaceId, sourceNodeId, targetNodeId, relationType])
  @@index([spaceId, createdAt])
}

model TimelineEvent {
  id               String             @id @default(cuid())
  spaceId          String
  eventType        TimelineEventType
  targetType       TimelineTargetType
  targetId         String
  nodeType         TimelineNodeType
  title            String
  summary          String
  description      String?
  impactSummary    String?
  isMainline       Boolean            @default(true)
  parentNodeId     String?
  branchFromNodeId String?
  mergeToNodeId    String?
  payload          Json?
  createdAt        DateTime           @default(now())
  space            Space              @relation(fields: [spaceId], references: [id])

  @@index([spaceId, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([spaceId, isMainline, createdAt])
}
